# =============================================
# RAG AI 어시스턴트 환경설정
# =============================================

# --- Ollama LLM 설정 ---
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.1:8b

# --- 임베딩 모델 경로 (허깅페이스 로컬 다운로드 경로) ---
EMBEDDING_MODEL_PATH=./models/bge-m3
RERANKER_MODEL_PATH=./models/bge-reranker-v2-m3

# --- Qdrant 벡터 DB 설정 ---
QDRANT_PATH=./data/qdrant_data
COLLECTION_NAME=documents
SCHEMA_COLLECTION=schema
VECTOR_SIZE=1024

# --- DB 타입 선택: sqlite | postgresql | oracle ---
DB_TYPE=postgresql

# --- SQLite (DB_TYPE=sqlite 일 때) ---
DB_PATH=./data/app.db

# --- PostgreSQL (DB_TYPE=postgresql 일 때) ---
PG_HOST=localhost
PG_PORT=5432
PG_USER=myuser
PG_PASSWORD=mypassword
PG_DBNAME=mydb

# --- Oracle (DB_TYPE=oracle 일 때) ---
ORA_HOST=localhost
ORA_PORT=1521
ORA_USER=myuser
ORA_PASSWORD=mypassword
ORA_SERVICE=myservice

# --- 파일 저장 경로 ---
PROMPTS_PATH=./data/prompts
UPLOADS_PATH=./data/uploads

# --- 청킹 설정 ---
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# --- 검색 설정 ---
TOP_K=5
RERANK_TOP_K=3

# --- MCP 서버 설정 ---
MCP_SERVER_PORT=8765

# --- 복합질문 최대 반복 횟수 ---
MAX_ITERATIONS=3
